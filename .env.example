# Copy this file to .env for local development.
# Keep secrets in .env and keep reusable non-secret site config in sites/<site_id>/site.json.

QA_SITE_ID=example-site
QA_EMAIL=you@example.com
QA_PASSWORD=change-me

# Optional site-level overrides.
# Recommended: keep these in sites/<site_id>/site.json unless you need a local-only override.
# QA_BASE_URL=https://example.com
# QA_SITE_NAME=Example Site
# QA_START_PATH=/dashboard
# QA_LOGIN_URL=
# QA_LOGIN_PATHS=/auth/sign-in,/login,/sign-in,/signin
# QA_AUTH_SUCCESS_PATHS=/dashboard,/project
# QA_AUTH_BLOCKING_PATHS=/auth/,/login,/signin,/sign-in,/verify,/otp,/forgot-password,/reset-password

QA_MAX_PAGES=300
QA_PUBLIC_CRAWL=1
QA_PUBLIC_MAX_PAGES=40
QA_PUBLIC_ROUTES=/,/auth/sign-in,/auth/sign-up,/auth/forgot-password,/forgot-password
QA_PARALLEL=10
QA_STRICT_ROUTE_DEDUPE=1
QA_PAGE_STATE_DEPTH=2
QA_MAX_STATE_ACTIONS=18
QA_MAX_PAGE_STATES=14
QA_MAX_FORM_FIELDS=10
QA_DISCOVERY_SEED_ROUTES=/,/dashboard
QA_SCENARIOS=1

QA_LLM_PROVIDER=ollama
QA_LLM_MODEL=qwen2.5
QA_LLM_URL=http://localhost:11434/v1/chat/completions
QA_LLM_REPORTING=1
# QA_LLM_ANALYSIS_MODEL=qwen2.5
# QA_LLM_REPORT_MODEL=qwen2.5:14b
# QA_LLM_API_KEY=
# QA_LLM_PREFLIGHT=1
# QA_LLM_FAIL_FAST=0

# Optional Ollama compatibility aliases.
OLLAMA_MODEL=qwen2.5
OLLAMA_URL=http://localhost:11434/v1/chat/completions

# Optional extras.
# QA_SLACK_WEBHOOK=
# QA_LANGGRAPH=0
